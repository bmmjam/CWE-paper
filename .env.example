# Copy this file to .env and fill in real values.
# .env is gitignored — never commit it.

# --- Providers: two budgets, routed by model id (see EXPERIMENTS.md §3.7) ---
# Model id WITHOUT "/" -> OpenAI direct ($30 budget).
# Model id WITH "/"    -> OpenRouter ($70 budget).
# OpenRouter ($70): gemini-flash-lite, deepseek, haiku/sonnet, open-weight.
OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_APP_NAME=paper5-mcts
OPENROUTER_SITE_URL=

# OpenAI ($30): gpt-4.1-nano / gpt-4.1-mini (weak end of the policy-strength axis).
OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=https://api.openai.com/v1

# --- Default models per role (no "/" = OpenAI, "/" = OpenRouter) ---
LLM_DEV=gpt-4.1-nano
LLM_CHEAP=gpt-4.1-nano
LLM_BASELINE=google/gemini-2.5-flash-lite
LLM_JUDGE=anthropic/claude-haiku-4.5
LLM_PREMIUM=anthropic/claude-sonnet-4.6
EMBED_MODEL=BAAI/bge-large-en-v1.5

# --- Inference defaults ---
LLM_TEMPERATURE=0.0
LLM_MAX_TOKENS=1024
LLM_TIMEOUT_SECONDS=60

# --- Caching ---
CACHE_DIR=.cache/llm
CACHE_ENABLED=true

# --- Logging / tracing (optional) ---
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=
# LANGCHAIN_PROJECT=AgentCLASS

# WANDB_API_KEY=
# WANDB_PROJECT=AgentCLASS
# WANDB_ENTITY=

# --- Data paths ---
DATA_DIR=data
RESULTS_DIR=results
CWE_TREE_PATH=data/cwe_tree.json

# --- MITRE CWE API ---
MITRE_CWE_API=https://cwe-api.mitre.org/api/v1
